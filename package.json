{
  "name": "@marko/vite",
  "version": "6.1.6",
  "description": "A Marko plugin for Vite",
  "keywords": [
    "loader",
    "marko",
    "plugin",
    "transform",
    "vite"
  ],
  "homepage": "https://github.com/marko-js/vite",
  "bugs": "https://github.com/marko-js/vite/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/marko-js/vite"
  },
  "license": "MIT",
  "author": "Dylan Piercey <dpiercey@ebay.com>",
  "main": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!**/__tests__",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -b && tsx build.mts",
    "change": "changeset add",
    "ci:test": "nyc pnpm test --forbid-only",
    "format": "pnpm run lint:eslint --fix && pnpm run lint:prettier --write",
    "lint": "tsc -b && pnpm run lint:eslint && pnpm run lint:prettier -l",
    "lint:eslint": "eslint -f unix .",
    "lint:prettier": "prettier \"./**/*{.ts,.js,.json,.md,.yml,rc}\"",
    "prepare": "husky",
    "release": "pnpm run build && changeset publish --tag ${NPM_CONFIG_TAG:-latest}",
    "report": "open ./coverage/lcov-report/index.html",
    "test": "cross-env NODE_ENV=test mocha \"./src/**/__tests__/*.test.ts\"",
    "test:inspect": "pnpm test --inspect",
    "test:update": "pnpm test --update",
    "version": "changeset version && pnpm install --lockfile-only"
  },
  "dependencies": {
    "@chialab/estransform": "^0.19.1",
    "anymatch": "^3.1.3",
    "domelementtype": "^2.3.0",
    "domhandler": "^5.0.3",
    "fast-glob": "^3.3.3",
    "htmljs-parser": "^5.10.2",
    "htmlparser2": "^10.1.0",
    "relative-import-path": "^1.0.0",
    "resolve-sync": "^1.2.2",
    "resolve.exports": "^2.0.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.1",
    "@marko/compiler": "^5.41.0",
    "@marko/fixture-snapshots": "^2.2.1",
    "@marko/testing-library": "^6.4.1",
    "@types/babel__core": "^7.20.5",
    "@types/diff": "^8.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/serve-handler": "^6.1.4",
    "cross-env": "^10.1.0",
    "diff": "^8.0.3",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.1",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "less": "^4.6.4",
    "lint-staged": "^16.4.0",
    "marko": "^5.39.14",
    "mocha": "^11.7.5",
    "mocha-snap": "^5.0.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "serve-handler": "^6.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "@marko/compiler": "^5",
    "vite": "^8"
  },
  "packageManager": "pnpm@11.15.1"
}
